{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx", "declarations/*.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "ai/**"],

  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "components/*": ["components/*"],
      "features/*": ["features/*"],
      "services/*": ["services/*"],
      "theme/*": ["theme/*"],
      "utils/*": ["utils/*"]
    },
    "typeRoots": ["./node_modules/@types", "./"],
    "strict": true,
    "resolveJsonModule": true
  }
}
